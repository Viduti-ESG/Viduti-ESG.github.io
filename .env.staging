# Green Curve — Staging environment
# Copy from .env and adjust values below.
# Never commit real secrets — this file is a template.

GC_ENV=staging
JWT_SECRET=staging-secret-change-me-32chars-min

# Staging DB — separate file so staging data never touches prod
GC_DB_PATH=/opt/greencurve/greencurve_staging.db

# API keys — use test/sandbox keys where available
ANTHROPIC_API_KEY=sk-ant-XXXX-staging

# SMTP — disable in staging by leaving blank
GC_SMTP_HOST=
GC_SMTP_PORT=587
GC_SMTP_USER=
GC_SMTP_PASS=
GC_NOTIFY_EMAIL=kneha2381@gmail.com

# Admin
GC_ADMIN_KEY=staging-admin-key
