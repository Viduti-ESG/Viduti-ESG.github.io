# Green Curve — environment variables
# Copy to .env and fill in values before starting the API service
# NEVER commit .env to git

# ── AI / LLM providers ────────────────────────────────────────────────────────
# AI features (CCTS, TCFD, NL query, PDF analysis, digest) route through one of:
#   GROQ_API_KEY      — FREE, no credit card, does NOT train on inputs, commercial-OK.
#                       Best for PUBLIC-company analysis. Get a key (2 min) at
#                       https://console.groq.com  →  API Keys  →  Create.
#   ANTHROPIC_API_KEY — frontier quality + DPA/Zero-Data-Retention for CLIENT data.
#                       Pay-as-you-go (needs a credit balance).
# GC_LLM_PROVIDER routes between them: auto (default) | groq | anthropic.
#   auto = try Groq first (works with zero Claude balance), then Claude if keyed.
GROQ_API_KEY=
GC_LLM_PROVIDER=auto
# Optional: override the Groq model (default llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=sk-ant-...

# Required: Admin key for supplier data management endpoints (DELETE /api/supplier-response)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
GC_ADMIN_KEY=

# Required: Secret key for JWT token signing (user auth)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Optional: set to "production" to suppress debug output
ENVIRONMENT=production

# Optional: GC_ENV controls startup checks (set to "production" for strict JWT enforcement)
GC_ENV=production

# Optional: outbound email (booking confirmations, pricing alerts, supplier
# notifications) via Microsoft Graph — the M365 tenant's Security defaults
# block legacy SMTP AUTH outright, so this uses the "GreenCurve-Mailer" Entra
# app registration (client-credentials flow) instead. Leave blank to disable
# — features degrade gracefully without it. See graph_mailer.py.
# MAIL_FROM must be a mailbox covered by the MailerScope Application Access
# Policy (currently neha@ and kdr@greencurve.solutions).
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
MAIL_FROM=neha@greencurve.solutions
NOTIFY_EMAIL=kneha2381@gmail.com
GC_NOTIFY_EMAIL=kneha2381@gmail.com

# Optional: Google Sign-In ("Continue with Google" on /login).
# Create a free OAuth Client ID at https://console.cloud.google.com
# (APIs & Services → Credentials → OAuth client ID → Web application,
#  Authorized JavaScript origins: https://greencurve.solutions).
# Leave blank to hide the Google button — email/password always works.
GOOGLE_CLIENT_ID=
